# ============================================
# .env.staging — Template des secrets
# ============================================
# Copier ce fichier en .env.staging et remplir les valeurs
# DO NOT commit .env.staging — c'est un secret local

# Database
DB_USERNAME=dony
DB_PASSWORD=your_secure_db_password_here

# Encryption (AES-256 base64, 32 bytes = 44 chars)
ENCRYPTION_KEY=your_base64_encryption_key_here

# Stripe
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# Monitoring
SENTRY_DSN=https://xxxx@sentry.io/xxxxx

# Google Places API
GOOGLE_PLACES_API_KEY=AIzaSyDxxxxxxxxxxxxxxxx

# Cloudflare R2 (S3-compatible)
AWS_S3_ENDPOINT=https://your-account.r2.cloudflarestorage.com
AWS_S3_REGION=auto
AWS_S3_BUCKET=dony-staging
AWS_S3_ACCESS_KEY=your_r2_access_key
AWS_S3_SECRET_KEY=your_r2_secret_key

# CORS
CORS_ALLOWED_ORIGINS=https://dony.store,http://localhost:3000

# Grafana Cloud (observabilité optionnelle en staging)
GRAFANA_PROM_URL=https://prometheus-blocks-prod-us-central1.grafana.net/api/prom/push
GRAFANA_PROM_USER=your_prom_user
GRAFANA_LOKI_URL=https://logs-prod-us-central1.grafana.net/loki/api/v1/push
GRAFANA_LOKI_USER=your_loki_user
GRAFANA_CLOUD_TOKEN=your_grafana_token

# Email (Resend pour notifications)
RESEND_API_KEY=re_xxxxxxxxxxxx

# Internal API secrets
INTERNAL_SHARED_SECRET=local_secret_change_for_prod
