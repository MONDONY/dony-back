# Config load test STAGING — copier en `staging.env` (gitignored) et remplir.
#   cp load-test/staging.env.example load-test/staging.env
#   # éditer staging.env, puis :
#   bash load-test/run_staging.sh

# ─── Cible ────────────────────────────────────────────────────────────────────
# DEUX choix de BASE_URL :
#
#  (a) Public via nginx — RATE-LIMITÉ à 30 req/min/IP (burst 10). Un load test
#      depuis une seule IP est throttlé (429) en quelques secondes. À RÉSERVER
#      à un smoke léger (valider que staging répond), PAS à un test de capacité.
#        BASE_URL=https://api-staging.dony.store/api/v1
#
#  (b) Backend DIRECT, en bypassant nginx → mesure la vraie capacité backend.
#      Nécessite d'atteindre le conteneur `dony_api` sur :8080. Options :
#        - lancer k6 SUR le VPS et publier le port 8080 du conteneur, puis :
#            BASE_URL=http://localhost:8080/api/v1
#        - lancer k6 comme conteneur dans le réseau docker staging :
#            BASE_URL=http://api:8080/api/v1
#      (voir STAGING.md § "Bypass du rate-limit nginx")
BASE_URL=

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Token Firebase ID pré-minté (PAS de /dev/token sur staging — il est @Profile("dev")).
# Validité ~1h. Voir STAGING.md § "Obtenir un token staging".
K6_ID_TOKEN=

# ─── Profil de charge ─────────────────────────────────────────────────────────
# Plateau simple :
READ_VUS=200
READ_DURATION=2m

# OU ramp multi-paliers pour trouver le point de rupture (prioritaire si défini).
# Format "cible:durée" séparés par des virgules. Décommente pour viser le ceiling :
# READ_STAGES=200:1m,1000:2m,3000:2m,5000:3m,8000:3m

# Inclure les écritures destructives (delete/cancel/payment…) ?
# ⚠️ DANGER sur des données staging réelles — laisser false sauf besoin précis.
INCLUDE_DESTRUCTIVE=false

# Garde anti-prod : par défaut le runner refuse toute URL ne contenant pas
# "staging", "localhost" ou "127.0.0.1". Mettre true UNIQUEMENT si tu testes une
# cible non-prod dont l'URL ne contient aucun de ces mots (à tes risques).
I_KNOW_ITS_NOT_PROD=false
