# Copy this file to .env.dev and fill in real values.
# NEVER commit .env.dev — it is in .gitignore

# ─── App ─────────────────────────────────────────────────────────────────────
export APP_BASE_URL=http://localhost:8080

# ─── Stripe (test) ───────────────────────────────────────────────────────────
export STRIPE_SECRET_KEY=replace_me
export STRIPE_WEBHOOK_SECRET=replace_me

# ─── Cloudflare R2 ───────────────────────────────────────────────────────────
export AWS_S3_REGION=auto
export AWS_S3_BUCKET=dony-app
export AWS_S3_ACCESS_KEY=replace_me
export AWS_S3_SECRET_KEY=replace_me
export AWS_S3_ENDPOINT=replace_me

# ─── Google Places + Geocoding API ───────────────────────────────────────────
# Create at: https://console.cloud.google.com/apis/credentials
# Enable: Places API + Geocoding API
# In prod: restrict to server IP (OVH fixed IP)
export GOOGLE_PLACES_API_KEY=replace_me

# ─── Encryption ──────────────────────────────────────────────────────────────
export ENCRYPTION_KEY=replace_me
