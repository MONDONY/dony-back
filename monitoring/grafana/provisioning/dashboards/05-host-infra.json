{
  "uid": "dony-host-infra",
  "title": "Dony — Hôte & Infrastructure",
  "description": "Métriques système du VPS : CPU, mémoire, disque, réseau, I/O (via Alloy node exporter)",
  "tags": ["dony", "host", "infra"],
  "timezone": "UTC",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {"from": "now-6h", "to": "now"},
  "panels": [
    {
      "id": 1,
      "title": "CPU (%)",
      "type": "gauge",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "100 - (avg(irate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)", "refId": "A", "datasource": {"type": "prometheus", "uid": "prometheus"}}
      ],
      "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100}},
      "gridPos": {"x": 0, "y": 0, "w": 6, "h": 6}
    },
    {
      "id": 2,
      "title": "Mémoire (%)",
      "type": "gauge",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "100 * (1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes))", "refId": "A", "datasource": {"type": "prometheus", "uid": "prometheus"}}
      ],
      "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100}},
      "gridPos": {"x": 6, "y": 0, "w": 6, "h": 6}
    },
    {
      "id": 3,
      "title": "Load average",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "node_load1", "legendFormat": "1m", "refId": "A", "datasource": {"type": "prometheus", "uid": "prometheus"}},
        {"expr": "node_load5", "legendFormat": "5m", "refId": "B", "datasource": {"type": "prometheus", "uid": "prometheus"}},
        {"expr": "node_load15", "legendFormat": "15m", "refId": "C", "datasource": {"type": "prometheus", "uid": "prometheus"}}
      ],
      "fieldConfig": {"defaults": {"unit": "short"}},
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 6}
    },
    {
      "id": 4,
      "title": "CPU par mode (%)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "avg by (mode) (irate(node_cpu_seconds_total{mode!=\"idle\"}[5m])) * 100", "legendFormat": "{{mode}}", "refId": "A", "datasource": {"type": "prometheus", "uid": "prometheus"}}
      ],
      "fieldConfig": {"defaults": {"unit": "percent", "custom": {"fillOpacity": 20, "stacking": {"mode": "normal"}}}},
      "gridPos": {"x": 0, "y": 6, "w": 12, "h": 8}
    },
    {
      "id": 5,
      "title": "Mémoire (détail)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "node_memory_MemTotal_bytes", "legendFormat": "total", "refId": "A", "datasource": {"type": "prometheus", "uid": "prometheus"}},
        {"expr": "node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes", "legendFormat": "utilisée", "refId": "B", "datasource": {"type": "prometheus", "uid": "prometheus"}},
        {"expr": "node_memory_Cached_bytes", "legendFormat": "cache", "refId": "C", "datasource": {"type": "prometheus", "uid": "prometheus"}},
        {"expr": "node_memory_Buffers_bytes", "legendFormat": "buffers", "refId": "D", "datasource": {"type": "prometheus", "uid": "prometheus"}}
      ],
      "fieldConfig": {"defaults": {"unit": "bytes"}},
      "gridPos": {"x": 12, "y": 6, "w": 12, "h": 8}
    },
    {
      "id": 6,
      "title": "Utilisation disque par point de montage (%)",
      "type": "bargauge",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "100 - (node_filesystem_avail_bytes{fstype!~\"tmpfs|overlay|squashfs|fuse.*\"} / node_filesystem_size_bytes{fstype!~\"tmpfs|overlay|squashfs|fuse.*\"} * 100)", "legendFormat": "{{mountpoint}}", "refId": "A", "datasource": {"type": "prometheus", "uid": "prometheus"}}
      ],
      "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100, "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 75}, {"color": "red", "value": 90}]}}},
      "gridPos": {"x": 0, "y": 14, "w": 8, "h": 8}
    },
    {
      "id": 7,
      "title": "Disque I/O (lecture/écriture)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "sum(rate(node_disk_read_bytes_total[5m]))", "legendFormat": "lecture", "refId": "A", "datasource": {"type": "prometheus", "uid": "prometheus"}},
        {"expr": "sum(rate(node_disk_written_bytes_total[5m]))", "legendFormat": "écriture", "refId": "B", "datasource": {"type": "prometheus", "uid": "prometheus"}}
      ],
      "fieldConfig": {"defaults": {"unit": "Bps"}},
      "gridPos": {"x": 8, "y": 14, "w": 8, "h": 8}
    },
    {
      "id": 8,
      "title": "Réseau (rx/tx)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "sum(rate(node_network_receive_bytes_total{device!~\"lo|veth.*|docker.*|br-.*\"}[5m]))", "legendFormat": "rx", "refId": "A", "datasource": {"type": "prometheus", "uid": "prometheus"}},
        {"expr": "sum(rate(node_network_transmit_bytes_total{device!~\"lo|veth.*|docker.*|br-.*\"}[5m]))", "legendFormat": "tx", "refId": "B", "datasource": {"type": "prometheus", "uid": "prometheus"}}
      ],
      "fieldConfig": {"defaults": {"unit": "Bps"}},
      "gridPos": {"x": 16, "y": 14, "w": 8, "h": 8}
    }
  ]
}
