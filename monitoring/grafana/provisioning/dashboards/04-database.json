{
  "uid": "dony-database",
  "title": "Dony — Base de données (HikariCP)",
  "description": "Pool de connexions JDBC HikariCP : connexions, attente, temps d'acquisition",
  "tags": ["dony", "database", "hikaricp"],
  "timezone": "UTC",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {"from": "now-6h", "to": "now"},
  "panels": [
    {
      "id": 1,
      "title": "Connexions actives",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "sum(hikaricp_connections_active{job=\"dony-api\"})", "refId": "A", "datasource": {"type": "prometheus", "uid": "prometheus"}}
      ],
      "fieldConfig": {"defaults": {"unit": "short"}},
      "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4}
    },
    {
      "id": 2,
      "title": "Connexions inactives",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "sum(hikaricp_connections_idle{job=\"dony-api\"})", "refId": "A", "datasource": {"type": "prometheus", "uid": "prometheus"}}
      ],
      "fieldConfig": {"defaults": {"unit": "short"}},
      "gridPos": {"x": 6, "y": 0, "w": 6, "h": 4}
    },
    {
      "id": 3,
      "title": "Threads en attente de connexion",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "sum(hikaricp_connections_pending{job=\"dony-api\"})", "refId": "A", "datasource": {"type": "prometheus", "uid": "prometheus"}}
      ],
      "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 1}, {"color": "red", "value": 5}]}}},
      "gridPos": {"x": 12, "y": 0, "w": 6, "h": 4}
    },
    {
      "id": 4,
      "title": "Timeouts de connexion (total)",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "sum(hikaricp_connections_timeout_total{job=\"dony-api\"})", "refId": "A", "datasource": {"type": "prometheus", "uid": "prometheus"}}
      ],
      "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 1}]}}},
      "gridPos": {"x": 18, "y": 0, "w": 6, "h": 4}
    },
    {
      "id": 5,
      "title": "Utilisation du pool (active / idle / pending vs max)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "sum(hikaricp_connections_active{job=\"dony-api\"})", "legendFormat": "actives", "refId": "A", "datasource": {"type": "prometheus", "uid": "prometheus"}},
        {"expr": "sum(hikaricp_connections_idle{job=\"dony-api\"})", "legendFormat": "inactives", "refId": "B", "datasource": {"type": "prometheus", "uid": "prometheus"}},
        {"expr": "sum(hikaricp_connections_pending{job=\"dony-api\"})", "legendFormat": "en attente", "refId": "C", "datasource": {"type": "prometheus", "uid": "prometheus"}},
        {"expr": "max(hikaricp_connections_max{job=\"dony-api\"})", "legendFormat": "max", "refId": "D", "datasource": {"type": "prometheus", "uid": "prometheus"}}
      ],
      "fieldConfig": {"defaults": {"unit": "short"}},
      "gridPos": {"x": 0, "y": 4, "w": 12, "h": 8}
    },
    {
      "id": 6,
      "title": "Temps d'acquisition de connexion p99 (ms)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "1000 * histogram_quantile(0.99, sum(rate(hikaricp_connections_acquire_seconds_bucket{job=\"dony-api\"}[5m])) by (le))", "legendFormat": "p99", "refId": "A", "datasource": {"type": "prometheus", "uid": "prometheus"}},
        {"expr": "1000 * histogram_quantile(0.95, sum(rate(hikaricp_connections_acquire_seconds_bucket{job=\"dony-api\"}[5m])) by (le))", "legendFormat": "p95", "refId": "B", "datasource": {"type": "prometheus", "uid": "prometheus"}}
      ],
      "fieldConfig": {"defaults": {"unit": "ms"}},
      "gridPos": {"x": 12, "y": 4, "w": 12, "h": 8}
    },
    {
      "id": 7,
      "title": "Durée d'utilisation des connexions p99 (ms)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "1000 * histogram_quantile(0.99, sum(rate(hikaricp_connections_usage_seconds_bucket{job=\"dony-api\"}[5m])) by (le))", "legendFormat": "p99", "refId": "A", "datasource": {"type": "prometheus", "uid": "prometheus"}}
      ],
      "fieldConfig": {"defaults": {"unit": "ms"}},
      "gridPos": {"x": 0, "y": 12, "w": 12, "h": 8}
    },
    {
      "id": 8,
      "title": "Temps de création de connexion p99 (ms)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "1000 * histogram_quantile(0.99, sum(rate(hikaricp_connections_creation_seconds_bucket{job=\"dony-api\"}[5m])) by (le))", "legendFormat": "p99", "refId": "A", "datasource": {"type": "prometheus", "uid": "prometheus"}}
      ],
      "fieldConfig": {"defaults": {"unit": "ms"}},
      "gridPos": {"x": 12, "y": 12, "w": 12, "h": 8}
    }
  ]
}
