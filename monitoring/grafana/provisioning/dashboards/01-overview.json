{
  "dashboard": {
    "title": "Dony — Vue Globale",
    "description": "État global du système : API, DB, Infrastructure",
    "tags": ["dony", "overview"],
    "timezone": "UTC",
    "panels": [
      {
        "id": 1,
        "title": "API Status",
        "type": "stat",
        "targets": [
          {
            "expr": "up{job=\"dony-api\"}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": {},
            "mappings": [
              {"type": "value", "options": {"0": {"color": "red", "text": "DOWN"}, "1": {"color": "green", "text": "UP"}}}
            ]
          }
        },
        "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4}
      },
      {
        "id": 2,
        "title": "Requêtes / sec",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(http_server_requests_seconds_count{job=\"dony-api\"}[1m])",
            "refId": "A"
          }
        ],
        "gridPos": {"x": 6, "y": 0, "w": 12, "h": 8}
      },
      {
        "id": 3,
        "title": "Latence p99 (ms)",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.99, rate(http_server_requests_seconds_bucket{job=\"dony-api\"}[5m])) * 1000",
            "refId": "A"
          }
        ],
        "gridPos": {"x": 18, "y": 0, "w": 6, "h": 8}
      },
      {
        "id": 4,
        "title": "CPU Usage",
        "type": "gauge",
        "targets": [
          {
            "expr": "100 - (avg(irate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": {},
            "unit": "percent",
            "max": 100
          }
        },
        "gridPos": {"x": 0, "y": 8, "w": 6, "h": 6}
      },
      {
        "id": 5,
        "title": "Memory Usage",
        "type": "gauge",
        "targets": [
          {
            "expr": "100 * (1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes))",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": {},
            "unit": "percent",
            "max": 100
          }
        },
        "gridPos": {"x": 6, "y": 8, "w": 6, "h": 6}
      },
      {
        "id": 6,
        "title": "Disk Usage",
        "type": "gauge",
        "targets": [
          {
            "expr": "100 - (node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"} * 100)",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": {},
            "unit": "percent",
            "max": 100
          }
        },
        "gridPos": {"x": 12, "y": 8, "w": 6, "h": 6}
      }
    ],
    "refresh": "30s"
  },
  "overwrite": true
}
