{
  "uid": "dony-overview",
  "title": "Dony — Vue Globale",
  "description": "État global du système : API, DB, Infrastructure",
  "tags": ["dony", "overview"],
  "timezone": "UTC",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {"from": "now-6h", "to": "now"},
  "panels": [
    {
      "id": 1,
      "title": "API Status",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "up{job=\"dony-api\"}", "refId": "A", "datasource": {"type": "prometheus", "uid": "prometheus"}}
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {"type": "value", "options": {"0": {"color": "red", "text": "DOWN"}, "1": {"color": "green", "text": "UP"}}}
          ],
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]}
        }
      },
      "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4}
    },
    {
      "id": 2,
      "title": "Requêtes / sec",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "sum(rate(http_server_requests_seconds_count{job=\"dony-api\"}[1m]))", "refId": "A", "datasource": {"type": "prometheus", "uid": "prometheus"}}
      ],
      "fieldConfig": {"defaults": {"unit": "reqps"}},
      "gridPos": {"x": 6, "y": 0, "w": 12, "h": 8}
    },
    {
      "id": 3,
      "title": "Latence p99 (ms)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{job=\"dony-api\"}[5m])) by (le)) * 1000", "refId": "A", "datasource": {"type": "prometheus", "uid": "prometheus"}}
      ],
      "fieldConfig": {"defaults": {"unit": "ms"}},
      "gridPos": {"x": 18, "y": 0, "w": 6, "h": 8}
    },
    {
      "id": 4,
      "title": "CPU Usage",
      "type": "gauge",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "100 - (avg(irate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)", "refId": "A", "datasource": {"type": "prometheus", "uid": "prometheus"}}
      ],
      "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100}},
      "gridPos": {"x": 0, "y": 8, "w": 6, "h": 6}
    },
    {
      "id": 5,
      "title": "Memory Usage",
      "type": "gauge",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "100 * (1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes))", "refId": "A", "datasource": {"type": "prometheus", "uid": "prometheus"}}
      ],
      "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100}},
      "gridPos": {"x": 6, "y": 8, "w": 6, "h": 6}
    },
    {
      "id": 6,
      "title": "Disk Usage",
      "type": "gauge",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "100 - (sum(node_filesystem_avail_bytes{mountpoint=~\"/host/root|/\",fstype!~\"tmpfs|overlay|squashfs\"}) / sum(node_filesystem_size_bytes{mountpoint=~\"/host/root|/\",fstype!~\"tmpfs|overlay|squashfs\"}) * 100)", "refId": "A", "datasource": {"type": "prometheus", "uid": "prometheus"}}
      ],
      "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100}},
      "gridPos": {"x": 12, "y": 8, "w": 6, "h": 6}
    }
  ]
}
